{
  "name": "whatspie-sdk",
  "version": "1.0.3",
  "description": "Universal, zero-dependency Whatspie WhatsApp API SDK for Node.js, Bun, and Edge.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fadhila36/whatspie-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/Fadhila36/whatspie-sdk/issues"
  },
  "homepage": "https://github.com/Fadhila36/whatspie-sdk#readme",
  "keywords": [
    "whatspie",
    "whatsapp",
    "api",
    "sdk",
    "messaging",
    "fetch",
    "edge",
    "universal"
  ],
  "author": "Muhammad Fadhila Abiyyu Faris <fadhila36>",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "cheerio": "^1.2.0",
    "eslint": "^8.57.0",
    "express": "^5.2.1",
    "prettier": "^3.2.5",
    "tsup": "^8.0.2",
    "typescript": "^5.4.3",
    "vitest": "^1.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
